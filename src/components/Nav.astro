---
import { SOCIALS } from '../config/socials';

interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const links = [
  { href: baseUrl,             label: 'Home'    },
  { href: baseUrl + 'about',   label: 'About'   },
  { href: baseUrl + 'blog',    label: 'Blog'    },
  { href: baseUrl + 'events',  label: 'Events'  },
  { href: baseUrl + 'contact', label: 'Contact' },
];
---

<header id="site-header">
  <div class="top-bar"></div>

  <nav class="nav-inner container">
    <a href={baseUrl} class="nav-logo">
      <img src={baseUrl + 'assets/logo.png'} alt="CoQatalyst logo" width="36" height="36" />
      <span class="nav-logo-text">CoQatalyst</span>
    </a>

    <div class="nav-links hide-mobile">
      {links.map(link => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href={SOCIALS.DISCORD.href}
        target="_blank"
        rel="noreferrer"
        class="btn-primary"
      >
        Join Discord &rarr;
      </a>
    </div>

    <button id="nav-toggle" class="nav-burger show-mobile" aria-label="Toggle menu" style="display:none;">
      <span class="burger-icon">&#9776;</span>
    </button>
  </nav>

  <div id="nav-drawer" class="nav-drawer" style="display:none;">
    {links.map(link => (
      <a
        href={link.href}
        class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
      >
        {link.label}
      </a>
    ))}
    <a
      href={SOCIALS.DISCORD.href}
      target="_blank"
      rel="noreferrer"
      class="btn-primary"
      style="text-align:center;"
    >
      Join Discord &rarr;
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  const burgerIcon = toggle?.querySelector('.burger-icon');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (drawer) drawer.style.display = open ? 'flex' : 'none';
    if (burgerIcon) burgerIcon.innerHTML = open ? '&#10005;' : '&#9776;';
  });
</script>

<style>
  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
  }
  .top-bar {
    height: 3px;
    background: linear-gradient(90deg, #226d0b, #dfa651, #e88f1a, #cb1b3a, #226d0b);
    background-size: 200%;
  }
  .nav-inner {
    background: rgba(10,10,10,0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .nav-logo img { image-rendering: crisp-edges; border-radius: 6px; }
  .nav-logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #226d0b, #dfa651);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-burger {
    background: none;
    border: none;
    cursor: pointer;
    color: #f5f0e8;
    font-size: 1.4rem;
    line-height: 1;
    padding: 4px 8px;
  }
  .nav-drawer {
    flex-direction: column;
    gap: 20px;
    padding: 24px;
    background: rgba(10,10,10,0.98);
    border-bottom: 1px solid rgba(34,109,11,0.3);
  }
  .nav-drawer .nav-link { font-size: 1rem; }
  @media (max-width: 768px) {
    .nav-burger { display: flex !important; }
    .nav-links  { display: none !important; }
  }
</style>