---
import Base from '../../layouts/Base.astro';
import BlogList from '../../components/blog/BlogList';

const baseUrl = import.meta.env.BASE_URL;
---

<Base title="Blog — CoQatalyst" description="Read insightful articles on research, STEM, AI, and machine learning written by members of the CoQatalyst teen science community." currentPath={`${baseUrl}blog`}>
  <div style="padding-top:67px;">

    <section class="blog-hero">
      <div class="container">
        <div class="section-tag" style="margin-bottom:16px;">CoQatalyst Blog</div>
        <h1 class="font-display blog-h1">
          <span class="blog-h1-white">THOUGHTS FROM</span>
          <span class="gradient-text">OUR COMMUNITY</span>
        </h1>
        <p class="blog-sub">
          Research tips, community stories, science deep-dives — everything written by teens in the CoQatalyst community.
        </p>
      </div>
    </section>

    <BlogList client:load />

  </div>
</Base>

<style>
.blog-hero {
  padding: 80px 0 56px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  position: relative;
  overflow: hidden;
}
.blog-h1 {
  font-size: clamp(3rem, 7vw, 6rem);
  line-height: 0.95;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
}
.blog-h1-white { color: #f5f0e8; }
.blog-sub {
  color: rgba(245,240,232,0.5);
  font-size: 1rem;
  max-width: 480px;
  line-height: 1.7;
}
</style>
