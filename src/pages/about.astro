---
import Base from '../layouts/Base.astro';

const baseUrl = import.meta.env.BASE_URL;

const team = [
  { 
    name: 'Krishna Paliwal',       
    role: 'Founder & CTO',       
    image: 'assets/pfp1.jpeg',
    bio: 'he does all the TECHY stuff, the website, submission, hosting and everything else.' 
  },
  { 
    name: 'Ayush Nigam', 
    role: 'Co-Founder & CMO',   
    image: 'assets/pfp2.png',
    bio: 'He is the manager, does all the social media and communications and event hosting.' 
  },
];

const timeline = [
  { year: '2026', event: 'CoQatalyst Founded',   desc: 'Started with a small Discord server and a very big idea.' },
];

const values = [
  { title: 'Curiosity First',   desc: 'We ask "why" before we ask "how." No question is too small or too weird.',                     accent: '#226d0b', rgb: '34,109,11' },
  { title: 'Peer > Hierarchy',  desc: 'Learn from and teach your peers. No gatekeeping, no gatekeepers.',                             accent: '#e88f1a', rgb: '232,143,26' },
  { title: 'Show Your Work',    desc: 'Science is reproducible. We celebrate the process, not just the result.',                      accent: '#dfa651', rgb: '223,166,81' },
];
---

<Base title="About CoQatalyst" description="Learn about CoQatalyst's mission to empower teen scientists and foster rigorous research through exhibitions, competitions, and community collaboration." currentPath={`${baseUrl}about`}>
  <div style="padding-top:67px;">

    <section class="about-hero">
      <div class="about-orb"></div>
      <div class="container">
        <div class="section-tag" style="margin-bottom:20px;">Our Story</div>
        <h1 class="font-display about-h1">
          <span class="about-h1-white">BUILT BY</span>
          <span class="gradient-text">TEENS,</span>
          <span class="about-h1-dim">FOR TEENS</span>
        </h1>

        <div class="about-intro grid-2col">
          <div>
            <p class="about-p1">
              CoQatalyst started with a simple frustration: science education in school felt disconnected
              from real science. We wanted a community where teens could explore questions that actually
              interested them not just read textbook problems.
            </p>
            <p class="about-p2">
              So we built it. A community where high schoolers host exhibitions, share research,
              ask dumb questions without judgment, and discover that science is a conversation and a form of art,
              not a lecture.
            </p>
          </div>

          <div class="sharp-card mission-card">
            <div class="mission-label font-display">OUR MISSION</div>
            <p class="mission-text">
              &ldquo;To catalyse the growth of research by helping high schoolers learn how real research is done!&rdquo;
            </p>
            <div class="mission-line"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad tl-bg">
      <div class="container" style="max-width:900px;">
        <div style="text-align:center; margin-bottom:56px;">
          <div class="section-tag" style="justify-content:center; margin-bottom:16px;">Timeline</div>
          <h2 class="font-display section-h2">HOW WE GOT HERE</h2>
        </div>

        <div class="tl-wrap">
          <div class="tl-line"></div>
          {timeline.map(item => (
            <div class="tl-row">
              <div class="tl-year font-mono">{item.year}</div>
              <div class="tl-dot"></div>
              <div class="sharp-card tl-card">
                <div class="tl-event font-display">{item.event}</div>
                <div class="tl-desc">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="container">
        <div style="margin-bottom:44px;">
          <div class="section-tag" style="margin-bottom:14px;">The People</div>
          <h2 class="font-display section-h2">WHO RUNS THIS</h2>
        </div>

        <div class="team-grid">
          {team.map(member => (
            <div class="sharp-card team-card">
              <div class="team-avatar">
                <img 
                  src={`${baseUrl}${member.image}`} 
                  alt={member.name} 
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <div class="team-name font-display">{member.name}</div>
              <div class="team-role font-mono">{member.role}</div>
              <p class="team-bio">{member.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad" style="padding-bottom:120px;">
      <div class="container">
        <div style="margin-bottom:44px;">
          <div class="section-tag" style="margin-bottom:14px;">What We Stand For</div>
          <h2 class="font-display section-h2">
            OUR <span class="gradient-text">VALUES</span>
          </h2>
        </div>

        <div class="values-grid">
          {values.map(v => (
            <div
              class="value-cell"
              style={`border-left:3px solid ${v.accent}; --rgb:${v.rgb};`}
            >
              <div class="value-title font-display" style={`color:${v.accent};`}>{v.title}</div>
              <p class="value-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>
</Base>

<style>
.about-hero {
  padding: 100px 0 80px;
  position: relative;
  overflow: hidden;
}
.about-h1 {
  font-size: clamp(3rem, 8vw, 7rem);
  line-height: 0.95;
  margin-bottom: 40px;
  display: flex;
  flex-direction: column;
}
.about-h1-white { color: #f5f0e8; }
.about-h1-dim   { color: rgba(245,240,232,0.4); }

.about-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}
.about-p1 {
  color: rgba(245,240,232,0.7);
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: 20px;
}
.about-p2 {
  color: rgba(245,240,232,0.5);
  font-size: 0.95rem;
  line-height: 1.8;
}

.mission-card { padding: 32px; }
.mission-label {
  font-size: 1rem;
  letter-spacing: 0.2em;
  color: #226d0b;
  margin-bottom: 16px;
}
.mission-text {
  font-size: 1.25rem;
  font-weight: 700;
  line-height: 1.5;
  color: #f5f0e8;
}
.mission-line {
  margin-top: 20px;
  height: 3px;
  background: linear-gradient(90deg, #226d0b, #dfa651, #e88f1a);
  border-radius: 2px;
}

.section-pad { padding: 80px 0; }
.section-h2 {
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1;
  color: #f5f0e8;
}
.tl-bg {
  background: linear-gradient(180deg, transparent, rgba(34,109,11,0.04) 50%, transparent);
}
.tl-wrap { position: relative; }
.tl-line {
  position: absolute;
  left: 80px; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, #226d0b, #dfa651, #e88f1a, rgba(232,143,26,0));
}
.tl-row {
  display: flex;
  gap: 32px;
  margin-bottom: 44px;
  align-items: flex-start;
}
.tl-year {
  min-width: 80px;
  text-align: right;
  font-size: 0.68rem;
  color: #dfa651;
  letter-spacing: 0.1em;
  padding-top: 4px;
}
.tl-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  background: #226d0b;
  border: 2px solid #0a0a0a;
  outline: 2px solid rgba(34,109,11,0.4);
  flex-shrink: 0;
  margin-top: 3px;
  z-index: 1;
}
.tl-card { flex: 1; padding: 20px 24px; }
.tl-event {
  font-size: 1.3rem;
  letter-spacing: 0.04em;
  color: #f5f0e8;
  margin-bottom: 6px;
}
.tl-desc {
  color: rgba(245,240,232,0.5);
  font-size: 0.85rem;
  line-height: 1.6;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
}
.team-card {
  padding: 28px;
  transition: transform 0.2s;
}
.team-card:hover { transform: translateY(-4px); }

.team-avatar {
  width: 120px; 
  height: 120px;
  position: relative;
  margin-bottom: 24px;
  
  padding: 3px; 
  background:#dfa651;
  
  clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 15px, 100% 100%, 0 100%);
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.team-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 0 100%);
  transition: transform 0.5s ease;
}

.team-card:hover .team-avatar {
  transform: scale(1.05) rotate(2deg);
  background:#ffc163;
  box-shadow: 0 0 20px rgba(34, 109, 11, 0.3);
}
.team-card:hover .team-avatar img {
  transform: scale(1.1); 
}
.team-card {
  padding: 32px;
  transition: all 0.3s ease;
  background: #0a0a0a;
  border: 1px solid rgba(245, 240, 232, 0.05);
}
.team-card:hover {
  border-color: rgba(223, 166, 81, 0.3);
  background: rgba(255, 255, 255, 0.02);
}
.team-name {
  font-size: 1.3rem;
  letter-spacing: 0.04em;
  color: #f5f0e8;
  margin-bottom: 4px;
}
.team-role {
  font-size: 0.58rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #226d0b;
  margin-bottom: 12px;
}
.team-bio {
  color: rgba(245,240,232,0.5);
  font-size: 0.82rem;
  line-height: 1.6;
}

.values-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(255,255,255,0.06);
}
.value-cell {
  background: #0a0a0a;
  padding: 32px;
  transition: background 0.2s;
}
.value-cell:hover { background: rgba(var(--rgb), 0.06); }
.value-title {
  font-size: 1.4rem;
  letter-spacing: 0.04em;
  margin-bottom: 12px;
}
.value-desc {
  color: rgba(245,240,232,0.5);
  font-size: 0.85rem;
  line-height: 1.7;
}

@media (max-width: 768px) {
  .about-intro { grid-template-columns: 1fr; }
  .values-grid { grid-template-columns: 1fr; }
  .tl-line     { left: 70px; }
}
</style>
