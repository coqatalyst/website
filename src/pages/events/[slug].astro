---
import Base from '../../layouts/Base.astro';
import { ConvexHttpClient } from 'convex/browser';
import { marked } from 'marked';
import { api } from '../../../convex/_generated/api';

const baseUrl = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;

  if (!convexUrl) {
    console.warn('PUBLIC_CONVEX_URL not set, skipping event pre-rendering');
    return [];
  }

  const client = new ConvexHttpClient(convexUrl);

  try {
    const events = await client.query(api.events.listEvents);
    return events.map((event: any) => ({
      params: { slug: event.slug },
      props: { event },
    }));
  } catch (error) {
    console.error('Failed to fetch events:', error);
    return [];
  }
}

interface Props {
  event: any;
}

const { slug } = Astro.params;
let event = (Astro.props as Props).event;

// If no event provided (dynamic rendering), fetch it
if (!event && slug) {
  const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;

  if (!convexUrl) {
    return Astro.redirect('/under-construction');
  }

  try {
    const client = new ConvexHttpClient(convexUrl);
    event = await client.query(api.events.getEventBySlug, { slug });

    if (!event) {
      return Astro.redirect('/404');
    }
  } catch (error) {
    console.error('Failed to fetch event:', error);
    return Astro.redirect('/under-construction');
  }
}

if (!event) {
  return Astro.redirect('/404');
}

const contentHtml = await marked(event.description);
---

<Base
  title={`${event.title} — CoQatalyst Events`}
  description={event.excerpt}
  currentPath={`${baseUrl}events/${event.slug}`}
>
  <div style="padding-top:67px;">

    <header class="post-header">
      <div class="post-header-bg"></div>
      <div class="container post-header-inner">

        <nav class="breadcrumb font-mono">
          <a href={baseUrl} class="bc-link">Home</a>
          <span class="bc-sep">/</span>
          <a href={`${baseUrl}events`} class="bc-link">Events</a>
          <span class="bc-sep">/</span>
          <span class="bc-current">{event.title}</span>
        </nav>

        <div class="post-meta-row">
          <span
            class="post-tag font-mono"
            style={`color:${event.accent}; border-color:${event.accent}44;`}
          >
            {event.tag}
          </span>
          <span class="post-meta-txt font-mono">
            {event.date} &middot; {event.location}
          </span>
        </div>

        <h1 class="font-display post-title">{event.title}</h1>

        <p class="post-excerpt">{event.excerpt}</p>

        <div class="post-accent-line" style={`background: linear-gradient(90deg, ${event.accent}, #dfa651);`}></div>

      </div>
    </header>

    <div class="container post-layout">
      <article class="post-content prose" set:html={contentHtml} />

      <aside class="post-sidebar">
        <div class="sidebar-card sharp-card">
          <div class="sidebar-label font-mono">Date</div>
          <div class="sidebar-date">{event.date}</div>
        </div>

        <div class="sidebar-card sharp-card">
          <div class="sidebar-label font-mono">Location</div>
          <div class="sidebar-date">{event.location}</div>
        </div>

        <div class="sidebar-card sharp-card">
          <div class="sidebar-label font-mono">Capacity</div>
          <div class="sidebar-date">{event.capacity} seats</div>
        </div>

        <div class="sidebar-card sharp-card">
          <div class="sidebar-label font-mono">Price</div>
          <div class="sidebar-date">
            {event.isFree ? 'Free' : `₹${event.price}`}
          </div>
        </div>

        <a href={`${baseUrl}events`} class="btn-outline sidebar-back">
          &larr; All Events
        </a>
      </aside>
    </div>

    {event.coverImage && (
      <div class="container cover-image-section">
        <img
          src={event.coverImage}
          alt={event.title}
          class="cover-image"
        />
      </div>
    )}

    {event.imageGallery && event.imageGallery.length > 0 && (
      <div class="container gallery-section">
        <h2 class="gallery-title font-display">Gallery</h2>
        <div class="gallery-grid">
          {event.imageGallery.map((image: string) => (
            <img
              src={image}
              alt={`${event.title} gallery`}
              class="gallery-image"
            />
          ))}
        </div>
      </div>
    )}

    <div class="container post-footer">
      <a href={`${baseUrl}events`} class="btn-primary">
        &larr; Back to Events
      </a>
      <a href={`${baseUrl}contact`} class="btn-outline">
        Questions? Get in Touch
      </a>
    </div>

  </div>
</Base>

<style>
.post-header {
  padding: 72px 0 56px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  position: relative;
  overflow: hidden;
}
.post-header-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(34,109,11,0.05) 0%, transparent 100%);
  pointer-events: none;
}
.post-header-inner { position: relative; z-index: 1; }

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 24px;
  flex-wrap: wrap;
}
.bc-link { color: rgba(245,240,232,0.4); text-decoration: none; transition: color 0.2s; }
.bc-link:hover { color: #dfa651; }
.bc-sep { color: rgba(245,240,232,0.2); }
.bc-current { color: rgba(245,240,232,0.7); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.post-meta-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.post-tag {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 4px 10px;
  border: 1px solid;
  clip-path: polygon(0 0, calc(100% - 5px) 0, 100% 5px, 100% 100%, 0 100%);
}
.post-meta-txt { font-size: 0.62rem; letter-spacing: 0.08em; color: rgba(245,240,232,0.35); }

.post-title {
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 1;
  letter-spacing: 0.02em;
  color: #f5f0e8;
  margin-bottom: 20px;
  max-width: 900px;
}
.post-excerpt {
  font-size: 1.1rem;
  color: rgba(245,240,232,0.55);
  line-height: 1.7;
  max-width: 640px;
  margin-bottom: 28px;
}
.post-accent-line { height: 3px; width: 80px; border-radius: 2px; }

.post-layout {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 56px;
  padding: 56px 24px 40px;
  align-items: start;
}

.prose {
  color: rgba(245,240,232,0.75);
  font-size: 1rem;
  line-height: 1.85;
  min-width: 0;
}
.prose :global(h2) {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2rem;
  letter-spacing: 0.04em;
  color: #f5f0e8;
  margin: 48px 0 16px;
  line-height: 1;
}
.prose :global(h3) {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.4rem;
  letter-spacing: 0.04em;
  color: rgba(245,240,232,0.85);
  margin: 32px 0 12px;
  line-height: 1;
}
.prose :global(h4) {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #226d0b;
  margin: 24px 0 8px;
}
.prose :global(p) { margin: 0 0 20px; }
.prose :global(a) {
  color: #dfa651;
  text-decoration: underline;
  text-decoration-color: rgba(223,166,81,0.4);
  transition: text-decoration-color 0.2s;
}
.prose :global(a:hover) { text-decoration-color: #dfa651; }
.prose :global(strong) { color: #f5f0e8; font-weight: 700; }
.prose :global(em) { color: rgba(245,240,232,0.65); font-style: italic; }
.prose :global(ul), .prose :global(ol) { margin: 0 0 20px 20px; }
.prose :global(li) { margin-bottom: 8px; color: rgba(245,240,232,0.7); }
.prose :global(li::marker) { color: #226d0b; }
.prose :global(blockquote) {
  border-left: 3px solid #226d0b;
  margin: 28px 0;
  padding: 16px 20px;
  background: rgba(34,109,11,0.07);
  clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);
  color: rgba(245,240,232,0.7);
  font-style: italic;
}
.prose :global(code) {
  font-family: 'Space Mono', monospace;
  font-size: 0.82rem;
  background: rgba(34,109,11,0.12);
  border: 1px solid rgba(34,109,11,0.25);
  padding: 2px 6px;
  color: #226d0b;
}
.prose :global(pre) {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 20px 24px;
  overflow-x: auto;
  margin: 0 0 24px;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);
}
.prose :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: rgba(245,240,232,0.8);
  font-size: 0.85rem;
}
.prose :global(hr) {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  margin: 40px 0;
}
.prose :global(img) {
  max-width: 100%;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.08);
  margin: 20px 0;
}
.prose :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 0 0 24px;
  font-size: 0.88rem;
}
.prose :global(th) {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #226d0b;
  border-bottom: 1px solid rgba(34,109,11,0.3);
  padding: 10px 12px;
  text-align: left;
}
.prose :global(td) {
  padding: 10px 12px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  color: rgba(245,240,232,0.65);
}

.post-sidebar {
  position: sticky;
  top: 88px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.sidebar-card { padding: 20px; }
.sidebar-label {
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.3);
  margin-bottom: 10px;
}
.sidebar-date { font-size: 0.88rem; color: rgba(245,240,232,0.65); }
.sidebar-back { display: block; text-align: center; margin-top: 4px; }

.cover-image-section {
  padding: 40px 24px;
}

.cover-image {
  width: 100%;
  height: auto;
  max-height: 500px;
  object-fit: cover;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.08);
}

.gallery-section {
  padding: 40px 24px;
}

.gallery-title {
  font-size: 2rem;
  letter-spacing: 0.04em;
  color: #f5f0e8;
  margin-bottom: 28px;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 16px;
}

.gallery-image {
  width: 100%;
  height: 250px;
  object-fit: cover;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.08);
  transition: transform 0.3s, box-shadow 0.3s;
}

.gallery-image:hover {
  transform: scale(1.02);
  box-shadow: 0 12px 24px rgba(34,109,11,0.2);
}

.post-footer {
  padding: 40px 24px 80px;
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  border-top: 1px solid rgba(255,255,255,0.05);
}

@media (max-width: 900px) {
  .post-layout { grid-template-columns: 1fr; }
  .post-sidebar { position: static; flex-direction: row; flex-wrap: wrap; }
  .sidebar-card { flex: 1; min-width: 140px; }
  .sidebar-back { width: 100%; }
}
@media (max-width: 600px) {
  .post-title { font-size: clamp(2rem, 9vw, 3rem); }
  .post-sidebar { flex-direction: column; }
  .sidebar-card { flex: none; }
}
</style>
