---
import Base from '../layouts/Base.astro';
import { SOCIALS } from '../config/socials';

const baseUrl = import.meta.env.BASE_URL;

const events: {
  title: string;
  date: string;
  location: string;
  type: 'upcoming' | 'past';
  tag: string;
  desc: string;
  accent: string;
  link?: string;
}[] = [
  // {
  //   title: 'abc',
  //   date: 'Mar 22, 2026',
  //   location: 'lko',
  //   type: 'upcoming',
  //   tag: 'Exhibition',
  //   desc: 'bruh',
  //   accent: '#226d0b',
  //   link: 'https://discord.gg/waitforsometimeig',
  // },
];

const upcoming = events.filter(e => e.type === 'upcoming');
const past     = events.filter(e => e.type === 'past');
const empty    = events.length === 0;
---

<Base title="Events — CoQatalyst" description="Discover upcoming CoQatalyst events including exhibitions, competitions, and research discussions for teen scientists and science enthusiasts." currentPath={`${baseUrl}events`}>
  <div style="padding-top:67px;">

    <section class="ev-hero">
      <div class="container">
        <div class="section-tag" style="margin-bottom:16px;">Events</div>
        <h1 class="font-display ev-h1">
          <span class="ev-h1-white">WHERE SCIENCE</span>
          <span class="gradient-text">GOES LIVE</span>
        </h1>
        <p class="ev-sub">
          Exhibitions, workshops, and community sessions — all run by teens,
          for teens. Register, present, or just show up.
        </p>
      </div>
    </section>

    <div class="container ev-body">

      {empty ? (
        <div class="empty-state">

          <!-- Animated rings -->
          <div class="empty-rings" aria-hidden="true">
            <div class="e-ring e-ring--1"></div>
            <div class="e-ring e-ring--2"></div>
            <div class="e-ring e-ring--3"></div>
          </div>

          <div class="empty-inner">
            <!-- Morse-style animated dots -->
            <div class="morse font-mono" aria-hidden="true">
              <span class="m-dot m-dot--1"></span>
              <span class="m-dot m-dot--2"></span>
              <span class="m-dot m-dot--3"></span>
              <span class="m-dot m-dot--4"></span>
            </div>

            <h2 class="font-display empty-headline">
              WE'RE PLANNING<br />
              <span class="gradient-text">SOMETHING BIG</span>
            </h2>

            <p class="empty-desc">
              No events are listed right now — but the lab is buzzing.
              Join the Discord and be the first to hear when we announce.
            </p>

            <div class="empty-ctas">
              <a
                href={SOCIALS.DISCORD.href}
                target="_blank"
                rel="noreferrer"
                class="btn-primary"
              >
                Get Notified on Discord &rarr;
              </a>
              <a href={`${baseUrl}contact`} class="btn-outline">Suggest an Event</a>
            </div>

            <div class="ev-progress-label font-mono">
              <span class="pulse-dot"></span>
              Planning in progress
            </div>
          </div>

        </div>

      ) : (
        <div>

          {upcoming.length > 0 && (
            <div class="ev-section">
              <div class="section-tag" style="margin-bottom:32px;">Upcoming</div>
              <div class="ev-grid">
                {upcoming.map(ev => (
                  <div class="ev-card sharp-card" style={`--accent:${ev.accent};`}>
                    <div class="ev-card-header">
                      <span class="ev-tag font-mono" style={`color:${ev.accent};`}>{ev.tag}</span>
                      <span class="ev-badge ev-badge--upcoming font-mono">Upcoming</span>
                    </div>
                    <h3 class="font-display ev-title">{ev.title}</h3>
                    <p class="ev-desc">{ev.desc}</p>
                    <div class="ev-meta">
                      <div class="ev-meta-row font-mono">
                        <span class="ev-meta-label">Date</span>
                        <span class="ev-meta-val">{ev.date}</span>
                      </div>
                      <div class="ev-meta-row font-mono">
                        <span class="ev-meta-label">Where</span>
                        <span class="ev-meta-val">{ev.location}</span>
                      </div>
                    </div>
                    {ev.link && (
                      <a href={ev.link} target="_blank" rel="noreferrer" class="btn-primary ev-cta">
                        Register &rarr;
                      </a>
                    )}
                    <div class="ev-accent-line" style={`background:${ev.accent};`}></div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {past.length > 0 && (
            <div class="ev-section">
              <div class="section-tag" style="margin-bottom:32px;">Past Events</div>
              <div class="ev-grid">
                {past.map(ev => (
                  <div class="ev-card ev-card--past sharp-card">
                    <div class="ev-card-header">
                      <span class="ev-tag font-mono" style={`color:${ev.accent};`}>{ev.tag}</span>
                      <span class="ev-badge ev-badge--past font-mono">Past</span>
                    </div>
                    <h3 class="font-display ev-title ev-title--past">{ev.title}</h3>
                    <p class="ev-desc ev-desc--past">{ev.desc}</p>
                    <div class="ev-meta">
                      <div class="ev-meta-row font-mono">
                        <span class="ev-meta-label">Date</span>
                        <span class="ev-meta-val">{ev.date}</span>
                      </div>
                      <div class="ev-meta-row font-mono">
                        <span class="ev-meta-label">Where</span>
                        <span class="ev-meta-val">{ev.location}</span>
                      </div>
                    </div>
                    <div class="ev-accent-line" style={`background:${ev.accent}; opacity:0.4;`}></div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>
      )}

      {!empty && (
        <div class="propose-box">
          <div class="stripe-accent propose-stripe"></div>
          <div class="propose-inner">
            <div class="section-tag" style="justify-content:center; margin-bottom:16px;">Got an idea?</div>
            <h3 class="font-display propose-title">WANT TO HOST<br /><span class="gradient-text-2">AN EVENT?</span></h3>
            <p class="propose-desc">
              We're always looking for teens who want to run workshops,
              exhibitions, or panels. Reach out and let's make it happen.
            </p>
            <a href={`${baseUrl}contact`} class="btn-primary">Propose an Event &rarr;</a>
          </div>
        </div>
      )}

    </div>
  </div>
</Base>

<style>
.ev-hero {
  padding: 80px 0 60px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  position: relative;
  overflow: hidden;
}
.ev-h1 {
  font-size: clamp(3rem, 7vw, 6rem);
  line-height: 0.95;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
}
.ev-h1-white { color: #f5f0e8; }
.ev-sub {
  color: rgba(245,240,232,0.5);
  font-size: 1rem;
  max-width: 480px;
  line-height: 1.7;
}

.ev-body { padding: 60px 24px 100px; }
.ev-section { margin-bottom: 72px; }

.ev-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}
.ev-card {
  padding: 28px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}
.ev-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.35), 0 0 30px rgba(var(--accent), 0.08);
}
.ev-card--past { opacity: 0.65; }
.ev-card--past:hover { opacity: 0.85; }

.ev-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.ev-tag {
  font-size: 0.58rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}
.ev-badge {
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 3px 8px;
  clip-path: polygon(0 0, calc(100% - 4px) 0, 100% 4px, 100% 100%, 0 100%);
}
.ev-badge--upcoming { background: rgba(34,109,11,0.2);  color: #226d0b; border: 1px solid rgba(34,109,11,0.35); }
.ev-badge--past     { background: rgba(255,255,255,0.05); color: rgba(245,240,232,0.3); border: 1px solid rgba(255,255,255,0.08); }

.ev-title {
  font-size: 1.5rem;
  letter-spacing: 0.03em;
  color: #f5f0e8;
  line-height: 1.1;
  margin-bottom: 12px;
}
.ev-title--past { color: rgba(245,240,232,0.5); }
.ev-desc {
  font-size: 0.85rem;
  color: rgba(245,240,232,0.55);
  line-height: 1.7;
  margin-bottom: 20px;
}
.ev-desc--past { color: rgba(245,240,232,0.35); }

.ev-meta { margin-bottom: 20px; display: flex; flex-direction: column; gap: 6px; }
.ev-meta-row {
  display: flex;
  gap: 10px;
  font-size: 0.62rem;
  letter-spacing: 0.08em;
}
.ev-meta-label {
  text-transform: uppercase;
  color: rgba(245,240,232,0.3);
  min-width: 44px;
}
.ev-meta-val { color: rgba(245,240,232,0.65); }

.ev-cta { display: inline-block; margin-bottom: 20px; }

.ev-accent-line {
  height: 2px;
  width: 40px;
  margin-top: auto;
  transition: width 0.3s;
}
.ev-card:hover .ev-accent-line { width: 80px; }

.propose-box {
  margin-top: 60px;
  background: linear-gradient(135deg, rgba(34,109,11,0.1), rgba(232,143,26,0.06));
  border: 1px solid rgba(34,109,11,0.25);
  clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 24px 100%, 0 calc(100% - 24px));
  position: relative;
  overflow: hidden;
  text-align: center;
}
.propose-stripe { position: absolute; inset: 0; opacity: 0.15; pointer-events: none; }
.propose-inner { padding: 60px 40px; position: relative; z-index: 1; }
.propose-title {
  font-size: clamp(2rem, 4vw, 3.5rem);
  color: #f5f0e8;
  line-height: 1;
  margin-bottom: 16px;
}
.propose-desc {
  color: rgba(245,240,232,0.55);
  font-size: 0.95rem;
  line-height: 1.7;
  max-width: 440px;
  margin: 0 auto 28px;
}

.empty-state {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.empty-rings {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.e-ring {
  position: absolute;
  border-radius: 50%;
}
.e-ring--1 {
  width: 320px; height: 320px;
  border: 1px dashed rgba(34,109,11,0.2);
  animation: spinSlow 25s linear infinite;
}
.e-ring--2 {
  width: 520px; height: 520px;
  border: 1px dashed rgba(223,166,81,0.12);
  animation: spinSlow 40s linear infinite reverse;
}
.e-ring--3 {
  width: 700px; height: 700px;
  border: 1px solid rgba(255,255,255,0.04);
}

@keyframes spinSlow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.empty-inner {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 560px;
}

.morse {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 8px;
  margin-bottom: 32px;
  height: 20px;
}
.m-dot {
  border-radius: 50%;
  background: #226d0b;
  box-shadow: 0 0 8px rgba(34,109,11,0.6);
}
.m-dot--1 { width: 8px;  height: 8px;  animation: blink 1.6s ease-in-out infinite 0.0s; }
.m-dot--2 { width: 20px; height: 8px; border-radius: 4px; animation: blink 1.6s ease-in-out infinite 0.2s; background: #dfa651; box-shadow: 0 0 8px rgba(223,166,81,0.5); }
.m-dot--3 { width: 8px;  height: 8px;  animation: blink 1.6s ease-in-out infinite 0.5s; background: #e88f1a; box-shadow: 0 0 8px rgba(232,143,26,0.5); }
.m-dot--4 { width: 20px; height: 8px; border-radius: 4px; animation: blink 1.6s ease-in-out infinite 0.8s; background: #cb1b3a; box-shadow: 0 0 8px rgba(203,27,58,0.5); }

@keyframes blink {
  0%, 100% { opacity: 0.2; transform: scaleY(1); }
  50%       { opacity: 1;   transform: scaleY(1.3); }
}

.empty-headline {
  font-size: clamp(2.5rem, 7vw, 5rem);
  line-height: 1;
  margin-bottom: 24px;
  color: #f5f0e8;
}
.empty-desc {
  color: rgba(245,240,232,0.55);
  font-size: 1rem;
  line-height: 1.75;
  margin-bottom: 36px;
}
.empty-ctas {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 32px;
}

.ev-progress-label {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.3);
  border: 1px solid rgba(255,255,255,0.07);
  padding: 7px 16px;
  clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
}
.pulse-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #226d0b;
  box-shadow: 0 0 6px #226d0b;
  animation: blink 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .ev-grid { grid-template-columns: 1fr; }
  .e-ring--2, .e-ring--3 { display: none; }
  .empty-state { min-height: auto; padding: 40px 0; }
}
</style>